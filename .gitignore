# Dependencias de Node (No subirlas nunca)
node_modules/
backend/node_modules/
frontend/node_modules/

# Base de datos local (Para que cada uno tenga sus datos de prueba locales)
backend/data/*.db
backend/data/*.db-journal

# Compilación de producción del Frontend (Se genera con npm run build)
frontend/dist/

# Archivos de configuración del entorno locales / secretos
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs de error de npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Archivos temporales del sistema operativo o editores
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp